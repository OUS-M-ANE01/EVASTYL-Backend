# MongoDB
MONGODB_URI=mongodb://localhost:27017/asma

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend Public URL (pour ngrok en dev, domaine en prod)
BACKEND_PUBLIC_URL=http://localhost:5000

# NabooPay
NABOOPAY_API_KEY=your-naboopay-api-key
NABOOPAY_WEBHOOK_SECRET=your-webhook-secret

# Email (Brevo/Sendinblue)
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@asma.com
EMAIL_FROM_NAME=ASMA

# Cloudinary (pour upload images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Admin par défaut
ADMIN_EMAIL=admin@asma.com
ADMIN_PASSWORD=changeme123
